{
  "miniprogramRoot": "src/miniprogram/",
  "projectname": "billion-whys",
  "description": "十亿个什么与为什么 - 2-6岁儿童好奇心即时响应小程序",
  "appid": "wxb8d98b0d4b1d9d97",
  "setting": {
