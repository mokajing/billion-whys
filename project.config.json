  "compileType": "miniprogram",
  "libVersion": "3.5.0",
  "minimumLibVersion": "2.10.4",
  "srcMiniprogramRoot": "src/miniprogram/",
  "packOptions": {
    "ignore": [
      {
        "type": "folder",
        "value": "../h5"
      },
      {
        "type": "folder",
        "value": "../../node_modules"
      },
      {
        "type": "folder",
        "value": "../../scripts"
      },
      {
        "type": "folder",
        "value": "../../coverage"
      }
    ]
  },
  "editorSetting": {
    "tabIndent": "insertSpaces",
    "tabSize": 2
