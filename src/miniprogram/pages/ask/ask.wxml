<view class="ask-page">
  <view class="ask-header">
    <text class="header-title">{{t['ask.title']}}</text>
    <text class="header-sub">{{t['ask.subtitle']}}</text>
  </view>

  <view class="search-box" aria-role="search">
    <text class="search-icon">🔍</text>
    <input
      value="{{keyword}}"
      type="text"
      placeholder="{{t['ask.placeholder']}}"
      maxlength="50"
      aria-label="{{t['ask.searchAria']}}"
      bindinput="onInput"
      confirm-type="search"
      bindconfirm="doSearch"
    />
    <view wx:if="{{keyword}}" class="clear-btn" bindtap="onClear" aria-role="button" aria-label="{{t['ask.clearAria']}}">
      <text>✕</text>
    </view>
  </view>

  <view wx:if="{{hasSearched && results.length > 0}}" class="search-results" aria-live="polite">
    <text class="results-title">{{resultsTitle}}</text>
    <view wx:for="{{results}}" wx:key="id"
      class="result-item" data-id="{{item.id}}" bindtap="onResultTap"
      aria-role="button" aria-label="{{item.question}}">
      <text class="ri-icon">💡</text>
      <view class="ri-content">
        <text class="ri-text">{{item.question}}</text>
        <text class="ri-tags">{{item.tagsText}}</text>
      </view>
      <text class="ri-arrow">›</text>
    </view>
  </view>

  <view wx:if="{{hasSearched && results.length === 0}}" class="no-result" aria-live="polite">
    <view class="nr-icon"><ip-face role="rabbit" size="48" /></view>
    <text class="nr-text">{{t['ask.noResult']}}</text>
    <text class="nr-sub">{{t['ask.suggestHint']}}</text>
    <view wx:if="{{suggestions.length > 0}}" class="suggest-section">
      <text class="suggest-title">{{t['ask.suggestTitle']}}</text>
      <view wx:for="{{suggestions}}" wx:key="id"
        class="result-item" data-id="{{item.id}}" bindtap="onResultTap"
        aria-role="button" aria-label="{{item.question}}">
        <text class="ri-icon">✨</text>
        <view class="ri-content">
          <text class="ri-text">{{item.question}}</text>
          <text class="ri-tags">{{item.tagsText}}</text>
        </view>
        <text class="ri-arrow">›</text>
      </view>
    </view>
  </view>

  <view wx:if="{{!keyword && recentSearches.length > 0}}" class="recent-section">
    <view class="recent-header">
      <text class="recent-title">{{t['ask.recentTitle']}}</text>
      <view class="recent-clear" bindtap="onClearHistory" aria-role="button" aria-label="{{t['ask.clearHistoryAria']}}">
        <text>{{t['ask.clearHistory']}}</text>
      </view>
    </view>
    <view class="recent-tags">
      <text wx:for="{{recentSearches}}" wx:key="*this"
        class="recent-tag" data-term="{{item}}" bindtap="onRecentTap"
        aria-role="button" aria-label="{{item}}">{{item}}</text>
    </view>
  </view>

  <view wx:if="{{!keyword}}" class="hot-section">
    <text class="hot-title">{{t['ask.hotTitle']}}</text>
    <view wx:for="{{hotQuestions}}" wx:key="id"
      class="hot-item" data-id="{{item.id}}" bindtap="onResultTap"
      aria-role="button" aria-label="{{item.question}}">
      <text class="hot-icon">❓</text>
      <text class="hot-text">{{item.question}}</text>
    </view>
  </view>

  <view wx:if="{{!keyword}}" class="hint-section">
    <text class="hint-label">{{t['ask.hintTitle']}}</text>
    <view class="hint-tags">
      <text wx:for="{{hints}}" wx:key="*this"
        class="hint-tag" data-hint="{{item}}" bindtap="onHintTap"
        aria-role="button" aria-label="{{item}}">{{item}}</text>
    </view>
  </view>
</view>
