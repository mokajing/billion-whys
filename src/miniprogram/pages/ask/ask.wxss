.ask-page { padding: 40rpx 32rpx 160rpx; }
.ask-header { text-align: center; margin-bottom: 40rpx; }
.header-title { display: block; font-size: 40rpx; font-weight: 700; color: #333; }
.header-sub { display: block; font-size: 26rpx; color: #767676; margin-top: 8rpx; }

.search-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f5f5f5;
  border-radius: 48rpx;
  padding: 20rpx 32rpx;
  margin-bottom: 32rpx;
}
.search-icon { font-size: 32rpx; flex-shrink: 0; }
.search-box input { flex: 1; font-size: 30rpx; color: #333; }
.clear-btn {
  width: 40rpx; height: 40rpx;
  background: #ddd; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 20rpx; color: #666;
}

.results-title { display: block; font-size: 24rpx; color: #767676; margin-bottom: 16rpx; }
.result-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.ri-icon { font-size: 36rpx; flex-shrink: 0; }
.ri-content { flex: 1; }
.ri-text { display: block; font-size: 30rpx; font-weight: 500; color: #333; }
.ri-tags { display: block; font-size: 22rpx; color: #767676; margin-top: 4rpx; }
.ri-arrow { font-size: 36rpx; color: #ccc; }

.no-result { text-align: center; padding: 80rpx 0; }
.nr-icon { display: block; font-size: 96rpx; margin-bottom: 24rpx; }
.nr-text { display: block; font-size: 30rpx; color: #666; }
.nr-sub { display: block; font-size: 24rpx; color: #767676; margin-top: 8rpx; }
.suggest-section { margin-top: 32rpx; text-align: left; }
.suggest-title { display: block; font-size: 26rpx; font-weight: 600; color: #666; margin-bottom: 16rpx; }

.hot-section { margin-bottom: 40rpx; }
.hot-title { display: block; font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.hot-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx 0; border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx; color: #333;
}
.hot-icon { font-size: 28rpx; }

.hint-section { margin-top: 32rpx; }
.hint-label { display: block; font-size: 24rpx; color: #767676; margin-bottom: 16rpx; }
.hint-tags { display: flex; gap: 16rpx; flex-wrap: wrap; }
.hint-tag {
  padding: 12rpx 24rpx; border-radius: 32rpx;
  background: #f0f8f4; font-size: 24rpx;
  color: #1A5C3A; border: 1rpx solid #e0f0e8;
}

.recent-section { margin-bottom: 32rpx; }
.recent-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16rpx;
}
.recent-title { font-size: 26rpx; font-weight: 600; color: #666; }
.recent-clear {
  padding: 4rpx 12rpx; border-radius: 20rpx;
  font-size: 22rpx; color: #999;
}
.recent-clear:active { background: #f0f0f0; color: #666; }
.recent-tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.recent-tag {
  padding: 12rpx 24rpx; border-radius: 32rpx;
  background: #f5f0ff; font-size: 24rpx;
  color: #6b4ea8; border: 1rpx solid #e8def5;
  max-width: 360rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.recent-tag:active { background: #6b4ea8; color: #fff; }
