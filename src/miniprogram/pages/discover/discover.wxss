.discover-page { padding-bottom: 120rpx; }
.discover-header { background: linear-gradient(135deg, #1A5C3A, #2E7D52); padding: 80rpx 48rpx 64rpx; border-radius: 0 0 48rpx 48rpx; }
.header-title { display: block; font-size: 44rpx; font-weight: 700; color: #fff; }
.header-sub { display: block; font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }

.category-tabs { display: flex; gap: 16rpx; padding: 32rpx; white-space: nowrap; }
.cat-tab { display: inline-flex; align-items: center; gap: 8rpx; padding: 12rpx 28rpx; border-radius: 32rpx; border: 2rpx solid #e0e0e0; background: #fff; font-size: 26rpx; flex-shrink: 0; }
.cat-tab.active { background: #1A5C3A; color: #fff; border-color: #1A5C3A; }
.cat-count { min-width: 36rpx; height: 36rpx; padding: 0 8rpx; border-radius: 18rpx; background: rgba(0,0,0,0.1); font-size: 20rpx; text-align: center; line-height: 36rpx; }
.cat-tab.active .cat-count { background: rgba(255,255,255,0.3); }

.question-list { padding: 0 32rpx; }
.question-item { display: flex; align-items: center; gap: 24rpx; padding: 28rpx 0; border-bottom: 2rpx solid #f0f0f0; }
.q-thumb { width: 104rpx; height: 104rpx; border-radius: 24rpx; overflow: hidden; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.q-thumb image { width: 100%; height: 100%; }
.q-thumb-body { background: linear-gradient(135deg, #FCE4EC, #F8BBD0); }
.q-thumb-home { background: linear-gradient(135deg, #FFF3E0, #FFE0B2); }
.q-thumb-food { background: linear-gradient(135deg, #F1F8E9, #DCEDC8); }
.q-thumb-nature { background: linear-gradient(135deg, #E0F7FA, #B2EBF2); }
.q-thumb-animals { background: linear-gradient(135deg, #FFF8E1, #FFECB3); }
.q-thumb-society { background: linear-gradient(135deg, #EDE7F6, #D1C4E9); }
.q-cat-icon { font-size: 48rpx; }
.q-content { flex: 1; }
.q-text { font-size: 30rpx; font-weight: 500; color: #333; }
.q-meta { display: flex; gap: 16rpx; margin-top: 8rpx; }
.q-tags { font-size: 22rpx; color: #767676; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 300rpx; }
.q-age { font-size: 22rpx; background: #FFF8E1; color: #E65100; padding: 2rpx 12rpx; border-radius: 8rpx; }
.q-arrow { font-size: 40rpx; color: #ccc; }

.expand-btn { text-align: center; padding: 24rpx; margin-top: 16rpx; border: 2rpx dashed #ccc; border-radius: 24rpx; background: #fafafa; color: #666; font-size: 26rpx; }

.loading-state { text-align: center; padding: 120rpx 48rpx; }
.loading-icon { display: block; font-size: 96rpx; margin-bottom: 24rpx; }
.loading-text { display: block; font-size: 28rpx; color: #767676; }
.retry-btn { display: inline-block; margin-top: 24rpx; padding: 16rpx 48rpx; background: #1A5C3A; color: #fff; border-radius: 32rpx; font-size: 28rpx; }

.daily-pick { padding: 0 32rpx; margin-bottom: 24rpx; }
.dp-card { display: flex; align-items: center; background: linear-gradient(135deg, #FFF9E6 0%, #FFE8C2 100%); border: 4rpx solid #FFD66B; border-radius: 32rpx; padding: 28rpx 32rpx; }
.dp-bubble { display: flex; align-items: center; gap: 24rpx; flex: 1; min-width: 0; }
.dp-rabbit { font-size: 64rpx; line-height: 1; flex-shrink: 0; }
.dp-bubble-text { min-width: 0; flex: 1; }
.dp-tag { display: block; font-size: 22rpx; color: #B25E00; font-weight: 600; margin-bottom: 6rpx; }
.dp-question { display: block; font-size: 30rpx; color: #3A2A00; font-weight: 500; line-height: 1.4; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
.dp-arrow { font-size: 48rpx; color: #B25E00; margin-left: 16rpx; flex-shrink: 0; }
