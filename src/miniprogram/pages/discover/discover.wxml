<view class="discover-page">
  <view class="discover-header">
    <text class="header-title">十亿个什么与为什么</text>
    <text class="header-sub">{{totalCount}} 个问题等你来探索</text>
  </view>

  <scroll-view class="category-tabs" scroll-x enable-flex aria-role="tablist" aria-label="内容分类">
    <view wx:for="{{categories}}" wx:key="key"
      class="cat-tab {{activeCategory === item.key ? 'active' : ''}}"
      aria-role="tab" aria-selected="{{activeCategory === item.key}}"
      data-key="{{item.key}}" bindtap="onCategoryTap">
      <text>{{item.icon}} {{item.label}}</text>
      <text wx:if="{{item.key !== 'all'}}" class="cat-count">{{item.count}}</text>
    </view>
  </scroll-view>

  <view wx:if="{{dailyPick && activeCategory === 'all'}}" class="daily-pick" aria-role="region" aria-label="今日好奇推荐">
    <view class="dp-card" bindtap="onDailyPickTap" aria-role="button" aria-label="今天的为什么 {{dailyPick.question}}">
      <view class="dp-bubble">
        <view class="dp-rabbit"><ip-face role="rabbit" size="32" /></view>
        <view class="dp-bubble-text">
          <text class="dp-tag">✨ 今天的为什么</text>
          <text class="dp-question">{{dailyPick.question}}</text>
        </view>
      </view>
      <text class="dp-arrow">›</text>
    </view>
  </view>

  <view class="question-list">
    <view wx:if="{{!totalCount && !loadError}}" class="loading-state" aria-live="polite">
      <view class="loading-icon"><ip-face role="rabbit" size="32" /></view>
      <text class="loading-text">问问兔正在准备中…</text>
    </view>

    <view wx:elif="{{loadError}}" class="loading-state" aria-live="polite">
      <text class="loading-icon">😿</text>
      <text class="loading-text">内容加载失败</text>
      <view class="retry-btn" bindtap="onRetry" aria-role="button" aria-label="重新加载">重新加载</view>
    </view>

    <block wx:else>
    <view wx:for="{{displayQuestions}}" wx:key="id"
      class="question-item" data-id="{{item.id}}" bindtap="onQuestionTap"
      aria-role="button" aria-label="{{item.question}}">
      <view class="q-thumb q-thumb-{{item.category}}">
        <image wx:if="{{item.thumbImage}}" src="{{item.thumbImage}}" mode="aspectFill" aria-label="{{item.question}}" lazy-load binderror="onThumbError" data-index="{{index}}" />
        <text wx:else class="q-cat-icon">{{categoryIcons[item.category] || '❓'}}</text>
      </view>
      <view class="q-content">
        <text class="q-text">{{item.question}}</text>
        <view class="q-meta">
          <text class="q-tags" wx:if="{{item.tags}}">{{item.tags}}</text>
          <text class="q-age">{{item.age}}</text>
        </view>
      </view>
      <text class="q-arrow">›</text>
    </view>

    <view wx:if="{{hasMore || expanded}}" class="expand-btn" bindtap="onToggleExpand" aria-role="button" aria-expanded="{{expanded}}">
      <text>{{expanded ? '收起' : '展开更多（共 ' + totalFiltered + ' 条）'}}</text>
    </view>
    </block>
  </view>
</view>
