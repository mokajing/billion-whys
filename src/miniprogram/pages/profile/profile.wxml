<view class="profile-page">
  <view class="profile-header">
    <view class="avatar"><ip-face role="rabbit" size="56" /></view>
    <view class="title">{{t['profile.title']}}</view>
    <view class="subtitle">{{t['qd.warmClosing']}}</view>
  </view>

  <view class="stats-card" aria-label="{{t['profile.statsAria']}}">
    <view class="stat-item" aria-label="{{statLibraryAria}}">
      <view class="stat-num">{{totalQuestions}}</view>
      <view class="stat-label">{{t['profile.statLibrary']}}</view>
    </view>
    <view class="stat-item" aria-label="{{statViewedAria}}">
      <view class="stat-num">{{viewedCount}}</view>
      <view class="stat-label">{{t['profile.statViewed']}}</view>
    </view>
    <view class="stat-item" aria-label="{{statStreakAria}}">
      <view class="stat-num">{{streakDays}}</view>
      <view class="stat-label">{{t['profile.statStreak']}}</view>
    </view>
    <view class="stat-item" aria-label="{{statFavAria}}">
      <view class="stat-num">{{favoriteCount}}</view>
      <view class="stat-label">{{t['profile.statFav']}}</view>
    </view>
    <view class="stat-item" aria-label="{{statFeedbackAria}}">
      <view class="stat-num">{{feedbackCount}}</view>
      <view class="stat-label">{{t['profile.statFeedback']}}</view>
    </view>
  </view>

  <view wx:if="{{streakMessage}}" class="streak-message" aria-live="polite">
    <text>{{streakMessage}}</text>
  </view>

  <view wx:if="{{summary.total > 0}}" class="ft-summary-card" aria-label="{{summaryAriaLabel}}">
    <view class="ft-summary-row">
      <text class="ft-summary-main">{{summaryTotalText}}</text>
      <text class="ft-summary-break">👍{{summary.up}} · 👎{{summary.down}} · ↻{{summary.reset}}</text>
    </view>
    <view wx:if="{{summary.showDepth}}" class="ft-summary-row ft-summary-depth">
      <text>{{summaryDepthText}}</text>
    </view>
    <view wx:if="{{previewCount + replayCount > 0}}" class="ft-summary-row ft-summary-channel">
      <text>{{summaryPreviewText}} · {{summaryReplayText}}</text>
    </view>
  </view>
  <view wx:else class="ft-summary-card ft-summary-empty" aria-label="{{summaryAriaLabel}}">
    <text class="ft-summary-empty-text">{{summaryEmptyText}}</text>
  </view>

  <view class="feedback-trend" aria-label="{{t['profile.trendAria']}}">
    <view class="ft-header">
      <text class="ft-title">{{trendTitleText}}</text>
      <view class="ft-legend">
        <text class="ft-leg ft-leg-up">👍</text>
        <text class="ft-leg ft-leg-down">👎</text>
        <text class="ft-leg ft-leg-reset">↻</text>
      </view>
    </view>
    <view wx:if="{{feedbackTrendTotal > 0}}" class="ft-bars-wrap">
      <view class="ft-bars" aria-label="{{trendBarAria}}">
        <view
          wx:for="{{feedbackTrend7d}}"
          wx:key="date"
          class="ft-bar-col {{expandedDay === item.date ? 'ft-bar-col-expanded' : ''}}"
          bindtap="onTapDay"
          data-date="{{item.date}}"
          data-total="{{item.total}}"
          aria-role="button"
          aria-expanded="{{expandedDay === item.date}}"
          aria-label="{{item.ariaLabel}}"
        >
          <view class="ft-bar-stack">
            <view class="ft-bar ft-bar-up" style="height:{{item.upH}}rpx;"></view>
            <view class="ft-bar ft-bar-down" style="height:{{item.downH}}rpx;"></view>
            <view class="ft-bar ft-bar-reset" style="height:{{item.resetH}}rpx;"></view>
          </view>
          <text class="ft-bar-label">{{item.label}}</text>
        </view>
      </view>
      <!-- V8.5 Sprint 14：当日明细（accordion 模式，同时只展开 1 列） -->
      <view wx:if="{{expandedDay}}" class="ft-detail" aria-label="{{dayDetailAria}}">
        <view class="ft-detail-header">
          <text>{{detailHeader}}</text>
        </view>
        <!-- V8.11 Sprint 20：当日反馈深度分布（L2+L3>0 才显示） -->
        <view wx:if="{{depthViz.show}}" class="ft-depth-viz" aria-label="{{depthViz.ariaLabel}}">
          <view class="ft-depth-bar">
            <view wx:if="{{depthViz.L1}}" class="ft-depth-seg ft-depth-seg-l1" style="width: {{depthViz.l1Pct}}%"></view>
            <view wx:if="{{depthViz.L2}}" class="ft-depth-seg ft-depth-seg-l2" style="width: {{depthViz.l2Pct}}%"></view>
            <view wx:if="{{depthViz.L3}}" class="ft-depth-seg ft-depth-seg-l3" style="width: {{depthViz.l3Pct}}%"></view>
          </view>
          <text class="ft-depth-text">{{depthViz.text}}</text>
        </view>
        <view wx:if="{{detailList.length > 0}}" class="ft-detail-list">
          <view
            wx:for="{{detailList}}"
            wx:key="time"
            class="ft-detail-item {{item.hasId ? 'ft-detail-item-clickable' : 'ft-detail-item-disabled'}}"
            bindtap="{{item.hasId ? 'onTapDetailItem' : ''}}"
            bindlongpress="{{item.hasId ? 'onPreviewDetail' : ''}}"
            data-id="{{item.id}}"
            aria-role="{{item.hasId ? 'button' : ''}}"
            aria-label="{{item.hasId ? item.replayAria : ''}}"
          >
            <text class="ft-detail-icon ft-detail-icon-{{item.action}}">{{item.icon}}</text>
            <text class="ft-detail-time">{{item.time}}</text>
            <text wx:if="{{item.showDepth}}" class="ft-detail-depth" aria-label="{{item.depthAria}}">{{item.depthText}}</text>
            <text class="ft-detail-title">{{item.title}}</text>
          </view>
        </view>
        <view wx:else class="ft-detail-empty">
          <text>{{t['profile.dayEmpty']}}</text>
        </view>
      </view>
    </view>
    <view wx:else class="ft-empty">
      <text>{{t['profile.trendEmpty']}}</text>
    </view>
  </view>

  <view class="menu-list" aria-role="list">
    <view class="mp-usage-card" aria-label="今日使用时长">
      <view class="mp-usage-row">
        <text class="mp-usage-label">今日剩余使用时间</text>
        <text class="mp-usage-value">{{remainingMin}} 分钟</text>
      </view>
      <view class="mp-usage-bar">
        <view class="mp-usage-bar-fill" style="width: {{usagePct}}%"></view>
      </view>
      <view class="mp-usage-row mp-usage-row-sub">
        <text>已使用 {{dailyUsedMin}} / 30 分钟</text>
        <text wx:if="{{parentVerified}}">家长验证 ✓</text>
      </view>
    </view>

    <!-- V8.73 第137轮：年龄偏好切换（周教授+叶用户+苏体验+前端小凡） -->
    <!-- Why: 多孩家庭需要切换年龄段，确认提示保护认知安全 -->
    <view class="mp-age-card" aria-label="宝贝年龄选择">
      <view class="mp-age-label">宝贝年龄</view>
      <view class="mp-age-options">
        <view
          wx:for="{{ageOptions}}"
          wx:key="value"
          class="mp-age-option {{agePreference === item.value ? 'mp-age-selected' : ''}}"
          data-age="{{item.value}}"
          bindtap="onAgeSwitch"
          aria-role="button"
          aria-label="{{item.label}}"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="menu-item" bindtap="onFeedback" aria-role="button" aria-label="{{t['profile.menuFeedbackAria']}}" aria-expanded="{{showFeedback}}">
      <text class="menu-icon">💬</text>
      <text class="menu-text">{{t['profile.menuFeedback']}}</text>
      <text class="menu-arrow {{showFeedback ? 'open' : ''}}">▼</text>
    </view>
    <view wx:if="{{showFeedback}}" class="feedback-panel" aria-live="polite">
      <text class="feedback-text">感谢您使用「十亿个什么与为什么」！如有任何建议或问题，欢迎联系我们：</text>
      <text class="feedback-email">📮 反馈邮箱：feedback@billionwhys.com</text>
      <text class="feedback-text">您的每一条建议都会帮助我们做得更好 🌱</text>
    </view>
    <view class="menu-item" bindtap="onAbout" aria-role="button" aria-label="{{t['profile.menuAboutAria']}}">
      <text class="menu-icon">📖</text>
      <text class="menu-text">{{t['profile.menuAbout']}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onPrivacy" aria-role="button" aria-label="{{t['profile.menuPrivacyAria']}}">
      <text class="menu-icon">🔒</text>
      <text class="menu-text">{{t['profile.menuPrivacy']}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onReport" aria-role="button" aria-label="举报不当内容">
      <text class="menu-icon">🚩</text>
      <text class="menu-text">举报不当内容</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onParentControl" aria-role="button" aria-label="家长控制面板">
      <text class="menu-icon">👨‍👩‍👧</text>
      <text class="menu-text">家长控制面板</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="version">{{versionFooterText}}</view>
</view>
