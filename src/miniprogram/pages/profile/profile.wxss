.profile-page {
  padding: 0 0 120rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.profile-header {
  background: linear-gradient(135deg, #1A5C3A, #2E7D52);
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
  border-radius: 0 0 40rpx 40rpx;
}
.avatar {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}
.subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
}

.stats-card {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  margin: -30rpx 32rpx 32rpx;
  padding: 32rpx 0;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.stat-item {
  text-align: center;
  min-width: 120rpx;
  flex: 1 1 30%;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A5C3A;
}
.stat-label {
  font-size: 22rpx;
  color: #767676;
  margin-top: 4rpx;
}

.streak-message {
  text-align: center;
  font-size: 26rpx;
  color: #C45000;
  font-weight: 500;
  padding: 16rpx 32rpx;
  margin: 0 32rpx 24rpx;
  background: #FFF8E1;
  border-radius: 16rpx;
}

/* V8.4 第72轮 Sprint 13：7 天反馈趋势可视化（H5 Profile.vue feedback-trend 同款） */
.feedback-trend {
  margin: 0 32rpx 24rpx;
  padding: 24rpx;
  background: #FAFAFA;
  border-radius: 20rpx;
}
/* V8.13 第81轮 Sprint 22：累计参与度汇总卡片（与 H5 Profile.vue 配色同构） */
.ft-summary-card {
  margin: 0 32rpx 24rpx;
  padding: 22rpx 28rpx;
  background: #E8F5E9;
  border-radius: 20rpx;
  min-height: 96rpx;
  display: flex;
  flex-direction: column;
}
.ft-summary-card.ft-summary-empty {
  background: #F5F5F5;
}
.ft-summary-row {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  margin-bottom: 8rpx;
}
.ft-summary-row.ft-summary-depth,
.ft-summary-row.ft-summary-channel {
  color: #388E3C;
}
.ft-summary-main {
  font-weight: 600;
  font-size: 30rpx;
  color: #2E7D32;
  margin-right: 16rpx;
}
.ft-summary-break {
  font-size: 26rpx;
  color: #4CAF50;
}
.ft-summary-depth,
.ft-summary-channel {
  font-size: 26rpx;
}
.ft-summary-empty-text {
  font-size: 28rpx;
  color: #555;
}
.ft-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.ft-title { font-size: 26rpx; font-weight: 600; color: #333; }
.ft-legend { display: flex; gap: 16rpx; font-size: 22rpx; color: #767676; }
.ft-leg { display: inline-flex; align-items: center; }
.ft-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 8rpx;
  height: 96rpx;
}
.ft-bar-col { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; min-height: 88rpx; padding: 4rpx 0; border-radius: 8rpx; }
.ft-bar-col-expanded { background: #FFF3E0; }
.ft-bars-wrap { display: flex; flex-direction: column; gap: 20rpx; }
/* V8.5 Sprint 14：当日明细 */
.ft-detail {
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
}
.ft-detail-header {
  font-size: 22rpx;
  color: #555;
  margin-bottom: 12rpx;
  font-weight: 500;
}
.ft-detail-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.ft-detail-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: #333;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}
.ft-detail-item:last-child { border-bottom: none; }
/* V8.6 Sprint 15：整行可点击（UX 苏体验：96rpx≈48px 触摸目标） */
.ft-detail-item-clickable {
  min-height: 96rpx;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
}
.ft-detail-item-clickable:active {
  background-color: #F5F5F5;
}
.ft-detail-item-disabled {
  /* 老 entry 无 id 不跳转，无视觉提示，避免误导 */
}
.ft-detail-icon { font-size: 24rpx; flex-shrink: 0; }
.ft-detail-icon-up { color: #4CAF50; }
.ft-detail-icon-down { color: #FF7043; }
.ft-detail-icon-reset { color: #BDBDBD; }
.ft-detail-time {
  color: #999;
  flex-shrink: 0;
  min-width: 72rpx;
}
/* V8.9 Sprint 18：深度徽章 — 仅 depth>1 显示（H5 Profile.vue 同款配色） */
.ft-detail-depth {
  background: #E8F5E9;
  color: #2E7D32;
  border-radius: 16rpx;
  padding: 2rpx 12rpx;
  font-size: 20rpx;
  flex-shrink: 0;
  white-space: nowrap;
}
.ft-detail-title {
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ft-detail-empty {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  padding: 16rpx 0;
}
/* V8.11 Sprint 20：当日反馈深度分布可视化 — 水平堆叠条 + 文案 */
.ft-depth-viz {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 12rpx 0 16rpx;
  padding: 12rpx 16rpx;
  background: #F1F8E9;
  border-radius: 12rpx;
}
.ft-depth-bar {
  display: flex;
  flex: 1;
  height: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #E0E0E0;
  min-width: 120rpx;
}
.ft-depth-seg {
  height: 100%;
}
.ft-depth-seg-l1 { background: #A5D6A7; }
.ft-depth-seg-l2 { background: #66BB6A; }
.ft-depth-seg-l3 { background: #2E7D32; }
.ft-depth-text {
  font-size: 20rpx;
  color: #2E7D32;
  flex-shrink: 0;
  white-space: nowrap;
}
.ft-bar-stack {
  height: 48rpx;
  display: flex;
  flex-direction: column-reverse;
  align-items: stretch;
  justify-content: flex-start;
  width: 60%;
  max-width: 36rpx;
}
.ft-bar { width: 100%; border-radius: 4rpx; }
.ft-bar-up { background: #4CAF50; }
.ft-bar-down { background: #FF7043; }
.ft-bar-reset { background: #BDBDBD; }
.ft-bar-label { font-size: 18rpx; color: #999; }
.ft-empty {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding: 24rpx 0 8rpx;
}

.menu-list {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}
.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
  transition: transform 0.3s;
}
.menu-arrow.open {
  transform: rotate(180deg);
}

.feedback-panel {
  padding: 24rpx 32rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  margin: 0 32rpx 16rpx;
}
.feedback-text {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 8rpx;
}
.feedback-email {
  display: block;
  font-size: 24rpx;
  color: #1A5C3A;
  font-weight: 500;
  margin: 8rpx 0;
}

.version {
  text-align: center;
  font-size: 22rpx;
  color: #767676;
  margin-top: 40rpx;
}

/* 未成年人保护：今日使用时长卡片 */
.mp-usage-card {
  margin: 16rpx 0;
  padding: 24rpx 28rpx;
  background: #E8F5E9;
  border-radius: 16rpx;
  border-left: 6rpx solid #1A5C3A;
}

.mp-usage-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  color: #333;
}

.mp-usage-row-sub {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.mp-usage-label {
  color: #1A5C3A;
  font-weight: 600;
}

.mp-usage-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A5C3A;
}

.mp-usage-bar {
  height: 12rpx;
  background: #fff;
  border-radius: 6rpx;
  margin: 12rpx 0;
  overflow: hidden;
}

.mp-usage-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #1A5C3A);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}
