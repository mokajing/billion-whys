.pv-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #f5f5f5 100%);
  padding: 48rpx 32rpx;
  box-sizing: border-box;
}

.pv-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.pv-avatar {
  margin: 0 auto 16rpx;
  width: 128rpx;
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pv-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A5C3A;
  margin-bottom: 12rpx;
}

.pv-subtitle {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding: 0 24rpx;
}

.pv-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.pv-progress {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.pv-question {
  margin-bottom: 24rpx;
}

.pv-q-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.pv-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.pv-option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.pv-option-selected {
  background: #E8F5E9;
  border-color: #1A5C3A;
}

.pv-option-letter {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #1A5C3A;
  color: #fff;
  border-radius: 50%;
  font-size: 26rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.pv-option-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.pv-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.pv-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.pv-btn-primary {
  background: #1A5C3A;
  color: #fff;
}

.pv-btn-secondary {
  background: #ECECEC;
  color: #333;
}

.pv-success {
  text-align: center;
  padding: 80rpx 0;
}

.pv-success-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.pv-success-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A5C3A;
  margin-bottom: 16rpx;
}

.pv-success-tip {
  font-size: 26rpx;
  color: #666;
}

.pv-footer {
  margin-top: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
}
