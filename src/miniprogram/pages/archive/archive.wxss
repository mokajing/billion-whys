.archive-page { padding: 40rpx 32rpx 160rpx; }
.archive-header { text-align: center; margin-bottom: 24rpx; }
.tab-bar {
  display: flex; justify-content: center; gap: 24rpx;
  margin-bottom: 32rpx;
}
.tab-item {
  padding: 12rpx 32rpx; font-size: 28rpx; color: #767676;
  border-radius: 24rpx; background: #f5f5f5;
}
.tab-item.active { background: #E8F5E9; color: #1A5C3A; font-weight: 600; }
.fav-star { color: #F9A825; font-size: 32rpx; margin-right: 12rpx; }
.header-title { display: block; font-size: 40rpx; font-weight: 700; color: #333; }
.header-sub { display: block; font-size: 26rpx; color: #767676; margin-top: 8rpx; }

.stats-bar {
  display: flex; justify-content: center; gap: 80rpx;
  margin-bottom: 40rpx; padding: 24rpx 0;
  background: #f0f8f4; border-radius: 20rpx;
}
.stat-item { text-align: center; }
.stat-num { display: block; font-size: 48rpx; font-weight: 700; color: #1A5C3A; }
.stat-label { display: block; font-size: 22rpx; color: #767676; margin-top: 4rpx; }

.empty-state { text-align: center; padding: 120rpx 0; }
.empty-icon { display: block; font-size: 96rpx; margin-bottom: 24rpx; }
.empty-text { display: block; font-size: 30rpx; color: #666; }
.empty-sub { display: block; font-size: 24rpx; color: #767676; margin-top: 8rpx; }
.go-btn {
  margin-top: 32rpx;
  background: #1A5C3A;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 16rpx 56rpx;
  line-height: 1.4;
}
.go-btn::after { border: none; }

.history-group { margin-bottom: 32rpx; }
.group-date {
  display: block; font-size: 26rpx; font-weight: 600;
  color: #767676; margin-bottom: 16rpx; padding-left: 4rpx;
}
.history-item {
  padding: 24rpx 20rpx; margin-bottom: 12rpx;
  background: #fff; border-radius: 16rpx;
  border: 1rpx solid #f0f0f0;
}
.hi-text { display: block; font-size: 30rpx; font-weight: 500; color: #333; }
.hi-meta { margin-top: 8rpx; }
.hi-age { font-size: 22rpx; color: #767676; }
