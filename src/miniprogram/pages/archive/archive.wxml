<view class="archive-page">
  <view class="archive-header">
    <text class="header-title">{{t['archive.title']}}</text>
    <text class="header-sub">{{t['archive.subtitle']}}</text>
  </view>

  <view class="tab-bar" aria-role="tablist" aria-label="{{t['archive.tabBarAria']}}">
    <view class="tab-item {{activeTab === 'history' ? 'active' : ''}}"
      data-tab="history" bindtap="onSwitchTab"
      aria-role="tab" aria-selected="{{activeTab === 'history'}}" aria-label="{{t['archive.tabHistory']}}">
      <text>{{t['archive.tabHistory']}}</text>
    </view>
    <view class="tab-item {{activeTab === 'favorites' ? 'active' : ''}}"
      data-tab="favorites" bindtap="onSwitchTab"
      aria-role="tab" aria-selected="{{activeTab === 'favorites'}}" aria-label="{{tabFavoritesAria}}">
      <text>{{tabFavoritesText}}</text>
    </view>
  </view>

  <view wx:if="{{activeTab === 'history'}}">
    <view wx:if="{{!isEmpty}}" class="stats-bar" aria-label="{{t['archive.statsAria']}}">
      <view class="stat-item" aria-label="{{statViewedAria}}">
        <text class="stat-num">{{totalViewed}}</text>
        <text class="stat-label">{{t['archive.statViewed']}}</text>
      </view>
      <view class="stat-item" aria-label="{{statTodayAria}}">
        <text class="stat-num">{{todayViewedCount}}</text>
        <text class="stat-label">{{t['archive.statToday']}}</text>
      </view>
      <view class="stat-item" aria-label="{{statStreakAria}}">
        <text class="stat-num">{{streakDays}}</text>
        <text class="stat-label">{{t['archive.statStreak']}}</text>
      </view>
    </view>

    <view wx:if="{{isEmpty}}" class="empty-state">
      <view class="empty-icon"><ip-face role="rabbit" size="48" /></view>
      <text class="empty-text">{{t['archive.emptyHistory']}}</text>
      <text class="empty-sub">{{t['archive.emptyHistorySub']}}</text>
      <button class="go-btn" bindtap="onGoDiscover" aria-label="{{t['archive.goDiscover']}}">{{t['archive.goDiscover']}}</button>
    </view>

    <view wx:for="{{historyGroups}}" wx:key="date" class="history-group">
      <text class="group-date">{{item.date}}</text>
      <view wx:for="{{item.items}}" wx:for-item="q" wx:key="id"
        class="history-item" data-id="{{q.id}}" bindtap="onQuestionTap"
        aria-role="button" aria-label="{{q.question}}">
        <text class="hi-text">{{q.question}}</text>
        <view class="hi-meta">
          <text class="hi-age">{{q.age}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{activeTab === 'favorites'}}">
    <view wx:if="{{favoriteCount === 0}}" class="empty-state">
      <text class="empty-icon">☆</text>
      <text class="empty-text">{{t['archive.emptyFav']}}</text>
      <text class="empty-sub">{{t['archive.emptyFavSub']}}</text>
      <button class="go-btn" bindtap="onGoDiscover" aria-label="{{t['archive.goDiscoverFav']}}">{{t['archive.goDiscoverFav']}}</button>
    </view>

    <view wx:for="{{favoriteList}}" wx:key="id"
      class="history-item" data-id="{{item.id}}"
      bindtap="onQuestionTap" bindlongpress="onFavoriteLongPress"
      aria-role="button" aria-label="{{item.favAria}}">
      <text class="fav-star">★</text>
      <text class="hi-text">{{item.question}}</text>
      <view class="hi-meta">
        <text class="hi-age">{{item.age}}</text>
      </view>
    </view>
  </view>
</view>
