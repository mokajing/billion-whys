<!--
  V8.23 Sprint 32 法务专项: 隐私政策正文 i18n 化
  - 与 H5 src/h5/pages/Profile.vue 隐私面板共享同一组 i18n key (profile.privacy.* / profile.agreement.*)
  - 毒舌老王: 原先 6 节结构冗余，统一为 H5 的 "5 条承诺 + 用户协议" 单一真相源
  - 法务张律: zh/en 同源同审，COPPA / GDPR-K / 《儿童个人信息网络保护规定》三重合规口径一致
  - 心理学家周教授: 正文给家长看，非儿童；en 用 "you/your child" 包容隔代抚养
-->
<view class="privacy-page" aria-role="article" aria-label="{{t['profile.privacy.title']}}">
  <view class="back-btn" bindtap="onBack" aria-role="button" aria-label="{{t['privacy.back']}}">{{t['privacy.back']}}</view>
  <view class="privacy-header">
    <text class="privacy-title" aria-role="heading" aria-level="1">{{t['profile.privacy.title']}}</text>
    <text class="privacy-version">{{t['privacy.versionLine']}}</text>
  </view>

  <view class="privacy-section">
    <text class="section-body">{{t['profile.privacy.intro']}}</text>
  </view>

  <view class="privacy-section">
    <text class="section-body">1. {{t['profile.privacy.zeroCollection.label']}}：{{t['profile.privacy.zeroCollection.body']}}</text>
  </view>
  <view class="privacy-section">
    <text class="section-body">2. {{t['profile.privacy.localStorage.label']}}：{{t['profile.privacy.localStorage.body']}}</text>
  </view>
  <view class="privacy-section">
    <text class="section-body">3. {{t['profile.privacy.noSharing.label']}}：{{t['profile.privacy.noSharing.body']}}</text>
  </view>
  <view class="privacy-section">
    <text class="section-body">4. {{t['profile.privacy.noAds.label']}}：{{t['profile.privacy.noAds.body']}}</text>
  </view>
  <view class="privacy-section">
    <text class="section-body">5. {{t['profile.privacy.localStats.label']}}：{{t['profile.privacy.localStats.body']}}</text>
  </view>

  <view class="privacy-section">
    <text class="section-title">{{t['profile.agreement.title']}}</text>
    <text class="section-body">{{t['profile.agreement.disclaimer']}}</text>
    <text class="section-body">{{t['profile.agreement.contact']}}</text>
  </view>

  <view class="privacy-footer">
    <text class="footer-text">{{t['privacy.footer']}}</text>
  </view>
</view>
