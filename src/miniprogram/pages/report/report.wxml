<view class="report-page">
  <view class="report-card">
    <view class="report-section">
      <view class="report-label">举报原因</view>
      <view class="report-reasons">
        <view
          wx:for="{{reasons}}"
          wx:key="value"
          class="report-reason {{selectedReason === item.value ? 'report-reason-selected' : ''}}"
          bindtap="onReasonChange"
          data-value="{{item.value}}"
        >{{item.label}}</view>
      </view>
    </view>

    <view wx:if="{{questionText}}" class="report-section">
      <view class="report-label">相关内容</view>
      <view class="report-question">{{questionText}}</view>
    </view>

    <view class="report-section">
      <view class="report-label">问题描述</view>
      <textarea
        class="report-textarea"
        placeholder="请详细描述您认为不当的内容，便于我们核查处理"
        maxlength="300"
        bindinput="onDescInput"
        value="{{description}}"
      />
      <view class="report-counter">{{description.length}} / 300</view>
    </view>
  </view>

  <view class="report-actions">
    <view class="report-btn report-btn-cancel" bindtap="onCancel">取消</view>
    <view class="report-btn report-btn-submit" bindtap="onSubmit">提交举报</view>
  </view>

  <view class="report-tip">您的举报将由人工核查，我们会在 1-3 个工作日内处理。</view>
</view>
