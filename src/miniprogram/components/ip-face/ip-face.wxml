<view class="ip-face ip-face--{{role}}{{mood === 'bowing' ? ' ip-face--bowing' : ''}}" style="width:{{size}}px;height:{{size}}px;" aria-hidden="true">
  <!-- 问问兔:前倾兔耳 + 白色圆脸 + 粉鼻 -->
  <block wx:if="{{role === 'rabbit'}}">
    <svg class="ip-face__svg" viewBox="0 0 48 48" width="{{size}}" height="{{size}}">
      <path d="M16 4 C 14 4 13 6 13.5 9 L 16 22 C 16.5 24 19.5 24 20 22 L 22.5 9 C 23 6 22 4 20 4 Z" fill="#FFFFFF"/>
      <path d="M28 4 C 26 4 25 6 25.5 9 L 28 22 C 28.5 24 31.5 24 32 22 L 34.5 9 C 35 6 34 4 32 4 Z" fill="#FFFFFF"/>
      <path d="M17 7 C 16.5 7 16 8 16.3 10 L 17.5 19 C 17.8 20 19.2 20 19.5 19 L 20.7 10 C 21 8 20.5 7 20 7 Z" fill="#F5B7C8"/>
      <path d="M29 7 C 28.5 7 28 8 28.3 10 L 29.5 19 C 29.8 20 31.2 20 31.5 19 L 32.7 10 C 33 8 32.5 7 32 7 Z" fill="#F5B7C8"/>
      <circle cx="24" cy="28" r="14" fill="#FFFFFF"/>
      <!-- V8.0 第69轮：bowing 态显示腮红，强化"真诚感谢"暖色调 -->
      <block wx:if="{{mood === 'bowing'}}">
        <circle cx="17" cy="31" r="2.2" fill="#FFC4B8" opacity="1"/>
        <circle cx="31" cy="31" r="2.2" fill="#FFC4B8" opacity="1"/>
      </block>
      <circle cx="19" cy="27" r="1.8" fill="#2B2B2B"/>
      <circle cx="29" cy="27" r="1.8" fill="#2B2B2B"/>
      <path d="M23 32 L 24 33.5 L 25 32 Z" fill="#E89AAB"/>
    </svg>
  </block>

  <!-- 答答熊:圆润小耳 + 温暖棕脸 + 浅口鼻区 + 深棕鼻 -->
  <block wx:else>
    <svg class="ip-face__svg" viewBox="0 0 48 48" width="{{size}}" height="{{size}}">
      <circle cx="13" cy="13" r="6" fill="#8B6244"/>
      <circle cx="35" cy="13" r="6" fill="#8B6244"/>
      <circle cx="13" cy="14" r="3" fill="#E8C8A0"/>
      <circle cx="35" cy="14" r="3" fill="#E8C8A0"/>
      <circle cx="24" cy="28" r="14" fill="#C8A47C"/>
      <ellipse cx="24" cy="33" rx="7" ry="5" fill="#EFD9B8"/>
      <circle cx="19" cy="27" r="1.8" fill="#2B2B2B"/>
      <circle cx="29" cy="27" r="1.8" fill="#2B2B2B"/>
      <ellipse cx="24" cy="31" rx="1.6" ry="1.2" fill="#5A3D2A"/>
    </svg>
  </block>
</view>
